# ──────────────────────────────────────────────────────────────────────────────
# Parchment — .gitignore
# Production-grade ignore rules for Android / Kotlin / Gradle projects
# ──────────────────────────────────────────────────────────────────────────────

# ── Build outputs ────────────────────────────────────────────────────────────
build/
app/build/
*.apk
*.aab
*.ap_
*.dex

# ── Gradle ───────────────────────────────────────────────────────────────────
.gradle/
gradle-app.setting
!gradle-wrapper.jar
!gradle-wrapper.properties

# ── IDE — Android Studio / IntelliJ IDEA ─────────────────────────────────────
.idea/
*.iml
*.iws
*.ipr
captures/
.externalNativeBuild/
.cxx/

# ── Kotlin ───────────────────────────────────────────────────────────────────
.kotlin/

# ── Local configuration ─────────────────────────────────────────────────────
local.properties

# ── Secrets & credentials (NEVER commit these) ───────────────────────────────
*.jks
*.keystore
*.p12
*.pem
*.key
google-services.json
firebase-*.json
.env
.env.*
!.env.example

# ── OS-specific ──────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
build_log*.txt

# ── Editor swap / backup files ───────────────────────────────────────────────
*.swp
*.swo
*.bak
*.tmp
*~

# ── Coverage / analysis reports ──────────────────────────────────────────────
coverage/
*.exec
*.ec

# ── Compiled outputs ────────────────────────────────────────────────────────
*.class
*.pyc
*.pyo

# ── Release artifacts (use GitHub Releases instead) ──────────────────────────
app/release/
